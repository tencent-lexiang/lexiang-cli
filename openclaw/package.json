{
    "name": "@tencent-lexiang/openclaw-lexiang",
    "version": "0.1.0",
    "description": "OpenClaw plugin for Lexiang",
    "type": "module",
    "main": "./dist/index.js",
    "files": [
        "dist/",
        "skills/",
        "bin/",
        "cli-config.json",
        "openclaw.plugin.json",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "generate:cli-config": "tsx scripts/generate-cli-config.ts",
        "prebuild": "pnpm run generate:cli-config",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.0.0",
        "@vitest/coverage-v8": "^3.0.0",
        "eslint": "^10.1.0",
        "globals": "^17.4.0",
        "openclaw": "2026.4.2",
        "tsx": "^4.0.0",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.58.0",
        "vitest": "^3.0.0"
    },
    "openclaw": {
        "extensions": [
            "./dist/index.js"
        ]
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    }
}